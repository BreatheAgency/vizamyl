<div class="row">
  <div class="small-5 large-5 columns with-content with-minimum">
    <h1>{{title}}</h1>
    <hr>
    {{controller}} | {{currentState}}
  </div>
  <div class="small-7 large-7 columns with-media">
    <video class="flex-video video-js vjs-sublime-skin" controls preload="auto" width="auto" height="auto">
      <source src="http://djqy74tsvke0j.cloudfront.net/test/playlist.m3u8" type='application/vnd.apple.mpegurl'/>
      <source src="http://djqy74tsvke0j.cloudfront.net/test/web.mp4" type='video/mp4'/>
      <source src="http://djqy74tsvke0j.cloudfront.net/test/web.webm" type='video/webm'/>
    </video>
    {{partial 'actions'}}
  </div>
</div>

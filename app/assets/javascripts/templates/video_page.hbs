<div {{bind-attr class=':row :video-page isSuperUser:super-user'}}>
  <div class='small-5 large-5 columns with-content with-minimum'>
    <h1>{{title}}</h1>
    <p>{{{body}}}</p>
    <div class="abbreviations">
      <p>{{{abbreviations}}}</p>
    </div>
  </div>
  <div class='small-7 large-7 columns with-media with-minimum'>
    {{video-player finished='finished' mandatory=mandatory source=source}}
    <div class='button-container row'>
      <div class='small-12 medium-12 large-12 columns'>
        <a {{bind-attr class=':right complete:enabled:disabled'}} {{action 'next' chapter step}}>{{i18n layouts.application.action_next}}<i class='fi-arrow-right'></i></a>
      </div>
    </div>
  </div>
</div>

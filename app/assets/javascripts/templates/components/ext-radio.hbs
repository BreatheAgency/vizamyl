{{ log '###################' }}
{{#each question in content}}
  <div class='question'>
    <label>{{radio-button value=question name=view.name selection=view.value}}
      <div class='body'>{{{question.body}}}</div></label>
  </div>

  {{#if dev }}
    {{#if question.correct }}
      {{ log "          ✅" }}
      {{ log " " }}
    {{else}}
      {{ log "          -" }}
      {{ log " " }}
    {{/if}}
  {{/if}}
{{/each}}

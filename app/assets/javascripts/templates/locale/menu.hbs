<section id="coursemenu__area" class="coursemenu__area">
  <div class="container">
    <div class="coursemenu__wrap">
      <div class="coursemenu__cards">
        <div class="accordion accordion-flush" id="accordionFlushExample">
          <div class="accordion-item">
            <h2 class="accordion-header" id="flush-headingOne">
              <button class="accordion-button coursebtn collapsed"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#flush-collapseOne">
                Introduction
              </button>
            </h2>
            <div id="flush-collapseOne"
                 class="accordion-collapse collapse"
                 data-bs-parent="#accordionFlushExample"
                 style="">
              <div class="accordion-body course_toggle_content">
                <div class="course__content">
                  <a href="#">Navigation</a>
                  <a href="#">Introduction</a>
                </div>
              </div>
            </div>
          </div>
          {{#each chapter in visibleChapters}}
          <div class="accordion-item">
            <h2 class="accordion-header" {{bind-attr id='chapter.headingId'}}>
              <button {{bind-attr data-bs-target='chapter.bsTarget'}}
                      class="accordion-button coursebtn collapsed"
                      type="button"
                      data-bs-toggle="collapse">
                {{{chapter.title}}}
              </button>
            </h2>
            <div {{bind-attr id='chapter.collapseId'}}
                 class="accordion-collapse collapse"
                 data-bs-parent="#accordionFlushExample"
                 style="">
              <div class="accordion-body course_toggle_content">
                <div class="course__content">
                  {{#each step in chapter.visibleSteps}}
                    <a class='list-group-item'>
                      {{{step.title}}}
                    </a>
                  {{/each}}
                </div>
              </div>
            </div>
          </div>
          {{/each}}
        </div>
      </div>
    </div>
  </div>
</section>


{{#each step in chapter.visibleSteps}}
  <li {{action 'selectStep' step}} {{bind-attr class='step.available:available:unavailable'}}>
    <h3>
      <a class='list-group-item'>
        {{{step.title}}}
      </a>
    </h3>
  </li>
{{/each}}

<div class='row page menu'>
  <div class='small-12 medium-12 large-12 columns with-content with-minimum' id='accordion'>
    <ol>
      {{#each chapter in visibleChapters}}
        <li {{bind-attr class=':panel :panel-default chapter.available:available:unavailable chapter.selected:selected:collapsed'}}>
          <div {{action 'toggle' chapter}} class='panel-heading'>
            <h2 class='panel-title'>
              <a>{{{chapter.title}}}</a>
            </h2>
          </div>
          <div {{bind-attr id=chapter.id}} class='panel-collapse collapse'>
            <ol class='list-group'>
              {{#each step in chapter.visibleSteps}}
                <li {{action 'selectStep' step}} {{bind-attr class='step.available:available:unavailable'}}>
                  <h3>
                    <a class='list-group-item'>
                      {{{step.title}}}
                    </a>
                  </h3>
                </li>
              {{/each}}
            </ol>
          </div>
        </li>
      {{/each}}
      {{#if isComplete}}
        {{#each chapter in hiddenChapters}}
          <li {{bind-attr class=':panel :panel-default chapter.available:available:unavailable chapter.selected:selected:collapsed'}}>
            <div {{action 'toggle' chapter}} class='panel-heading'>
              <h2 class='panel-title'>
                <a>{{{chapter.title}}}</a>
              </h2>
            </div>
            <div {{bind-attr id=chapter.id}} class='panel-collapse collapse'>
              <ul class="small-block-grid-6 list-block">
                {{#each step in chapter.visibleSteps}}
                  <li {{action 'selectStep' step}}><p class='container'>{{{step.title}}} <i class='fi-arrow-right right'></i></p></li>
                {{/each}}
              </ul>
            </div>
          </li>
        {{/each}}
      {{/if}}
      {{! Link to Adjunctive Use of Quantification }}
      {{#if isEuropean }}
        <li class='panel panel-default available collapsed'>
          <div class='panel-heading'>
            <h2 class='panel-title'>
              <a {{bind-attr href=useVideoLink}}>{{{ videoLinkText }}}</a>
            </h2>
          </div>
        </li>
      {{/if}}
      {{! Link to Vizamyl Refresher Video for Italians }}
      {{#if hasItalianOrigin }}
        <li class='panel panel-default available collapsed'>
          <div class='panel-heading'>
            <h2 class='panel-title'>
              <a href="/it/users/refresher" >Corso di aggiornamento</a>
            </h2>
          </div>
        </li>
      {{/if}}
    </ol>
  </div>
</div>
<div class='row page-footer'>
  <div class='small-6 medium-6 large-6 columns'>
    <div class='page-abbreviations'>
    </div>
  </div>
  <div class='small-6 medium-6 large-6 columns'>
    <div class='page-actions'>
    </div>
  </div>
</div>

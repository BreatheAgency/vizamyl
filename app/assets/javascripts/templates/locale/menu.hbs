<div class='row menu'>
  <div class='small-12 medium-12 large-12 columns with-content with-minimum' id='accordion'>
    <ol>
      {{#each chapter in controller}}
        <li {{bind-attr class=':panel :panel-default chapter.available:available'}}>
          <div class='panel-heading'>
            <h2 class='panel-title'>
              <a data-toggle='collapse' data-parent='#accordion' {{bind-attr href=chapter.hashId}}>{{chapter.title}}</a>
            </h2>
          </div>
          <div {{bind-attr id=chapter.id}} class='panel-collapse collapse'>
            <ol class='list-group'>
              {{#each step in chapter.steps}}
                <li>
                  <h3>
                    <a {{action 'select' chapter step}} {{bind-attr class=':list-group-item step.available:available'}}>
                      <i {{bind-attr class='step.progressClass'}}></i> {{step.title}}
                    </a>
                  </h3>
                </li>
              {{/each}}
            </ol>
          </div>
        </li>
      {{/each}}
    </ol>
  </div>
</div>

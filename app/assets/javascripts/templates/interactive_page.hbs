<section id="reference__area" class="reference__area">
  <div class="container">
    <div class="reference__wrap assessment__wrap">

      <div class="row g-3">
        <div class="col-md-7">
          <div class="assessmentquestion__content__img assessmentquestion__content__img2">
            <div class="assessmentquestion__content">
              <div class="multipart__span">
                <span>
                  {{{title}}}
                </span>
              </div>
              <h6 class="assessment2_title">
                {{{body}}}
              </h6>
              <p>{{{abbreviations}}}</p>
            </div>
          </div>
        </div>

        <div class="col-md-5">
          <div class="assessmentquestion__img disabled_questionscroll_img">

            {{#each interactive_source in interactive_sources}}
              <div {{bind-attr class=":columns columns"}}>
                {{#if interactive_source.hasUnsafeHeight}}
                  {{ log "multi-scroller" }}
                  {{multi-scroller imageWidth=interactiveWidth imageHeightMax=interactive_source.height source=interactive_source.sourceWithUrl images=interactive_source.images label=interactive_source.label}}
                {{else}}
                  {{ log "single-scroller" }}
                  {{single-scroller imageWidth=interactiveWidth imageHeightMax=interactive_source.height source=interactive_source.sourceWithUrl images=interactive_source.images label=interactive_source.label}}
                {{/if}}
              </div>
            {{/each}}
          </div>
        </div>

      </div>
    </div>
    <div class="page__select__next__prev">
      <a {{bind-attr class=':right complete:enabled:disabled'}}
         {{action 'next' step}}>
        {{i18n course.actions.next}}
        <img src="/assets/right_angle_purple.svg" alt="Right angle purple">
      </a>
    </div>
  </div>
</section>

<div {{bind-attr class=':row :interactive-page isSuperUser:super-user'}}>
  <div class='small-5 large-5 columns with-content with-minimum'>
    <h1>{{title}}</h1>
    <p>{{{body}}}</p>
  </div>
  <div class='small-7 large-7 columns with-media with-minimum'>
    <div class='image-scrollers row'>
      {{#each source in sourcesWithUrls}}
        <div {{bind-attr class=":columns triplet:small-4:small-6 triplet:large-4:large-6"}}>
          {{image-scroller imageHeight=imageHeight imageHeightMax=imageHeightMax src=source}}
        </div>
      {{/each}}
    </div>
    <div class='button-container row'>
      <div class='small-12 medium-12 large-12 columns'>
        <a {{bind-attr class=':right complete:enabled:disabled'}} {{action 'next' chapter step}}>{{i18n course.actions.next}}<i class='fi-arrow-right'></i></a>
      </div>
    </div>
  </div>
</div>

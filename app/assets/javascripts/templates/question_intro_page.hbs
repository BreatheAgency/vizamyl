<div class='row question-intro-page' {{bind-attr style='style'}}>
  <div class='small-12 medium-12 large-12 columns with-content with-minimum'>
    <div class='title-box'>
      <h1>{{title}}</h1>
    </div>
    <div class='body-box'>
      {{{body}}}
    </div>
    <div class='button-container row'>
      <div class='small-12 medium-12 large-12 columns'>
        <a {{bind-attr class=':right complete:enabled:disabled'}} href='/'>Next<i class='fi-arrow-right'></i></a>
      </div>
    </div>
  </div>
</div>

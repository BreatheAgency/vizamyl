$available-locales: <%= I18n.available_locales.map(&:to_s).join(' ') %>;
$global-font: 'geinspira', Helvetica, Arial, sans-serif;
$primary-color: #005cb9;
$primary-highlight: #009ee2;
$background-top: #e8e7e7;
$background-bottom: white;

@mixin non-retina {
  @media only screen and (min-resolution: 96dpi) {
    @content;
  }
}

@mixin retina {
  @media only screen and (-webkit-min-device-pixel-ratio: 2),
         only screen and (   min--moz-device-pixel-ratio: 2),
         only screen and (     -o-min-device-pixel-ratio: 2/1),
         only screen and (        min-device-pixel-ratio: 2),
         only screen and (                min-resolution: 192dpi),
         only screen and (                min-resolution: 2dppx) {
    @content;
  }
}

@mixin retina-background-image($image, $width: 50%, $height: auto, $type: 'png') {
  @include background-size($width $height);

  @include non-retina {
    @include background-image(asset-url("#{$image}.#{$type}"));
  }

  @include retina {
    @include background-image(asset-url("#{$image}@2x.#{$type}"));
  }
}

<div class='devise registrations us row'>
  <div class='small-12 medium-12 large-12 columns with-content with-minimum'>
    <div class="row">
      <div class="small-12 columns">
        <h1><%= t('.registration') %></h1>

        <% if locale.to_sym == :jp %>
          <h5><%= t('.privacy_link') %></h5>
        <% else %>
          <p><a href="http://www.ge.com/privacy" target="_blank"><%= t('.privacy_link') %></a></p>
        <% end %>
        <%= raw t('.privacy_statement') %>
        <p><small> * <%= raw t('.required_field') %></small></p>
      </div>
    </div>

    <%= render partial: 'non_european_enrol_form' %>
  </div>
</div>

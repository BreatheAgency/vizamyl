<section id="login__area" class="login__area">
  <div class="container non_euro_enrol">
    <div class="login__wrap">
      <div class="login__content">
        <h2><%= t('.registration') %></h2>
        <% if locale.to_sym == :jp %>
          <h5><%= t('.privacy_link') %></h5>
        <% else %>
          <p><a href="http://www.ge.com/privacy" target="_blank"><%= t('.privacy_link') %></a></p>
        <% end %>
        <%= raw t('.privacy_statement') %>
        <br>
        <br>
        <p>* <%= raw t('.required_field') %></p>
      </div>

      <div class="login__part">

        <%= render partial: 'non_european_enrol_form' %>

        <script>
         $(document).ready(function() {
           $('#user_marketing_overall_opt_in').click(function(e){
             $('#user_marketing_overall_opt_out').prop('checked', false).prop('required', false);
             $(this).prop('checked', true).prop('required', true);
           });
           $('#user_marketing_overall_opt_out').click(function(e){
             $('#user_marketing_overall_opt_in').prop('checked', false).prop('required', false);
             $(this).prop('checked', true).prop('required', true);
           });
         });
        </script>
      </div>
    </div>
  </div>
</section>

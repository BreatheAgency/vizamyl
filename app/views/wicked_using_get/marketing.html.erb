<div class='devise registrations row'>
  <div class='small-6 medium-6 large-6 columns with-content with-minimum'>
  </div>
  <div class='small-6 medium-6 large-6 columns with-content with-minimum'>
    <h1 class='vh'><%= t('.sign_up') %></h1>
    <%= simple_form_for(@user, url: wicked_using_get_index_path, html: { class: 'form' }) do |f| %>
      <%= render 'tmp_storage_fields', f: f %>
      <div class='form-inputs'>
        <%= f.input :marketing_overall_opt_in %>
        <%= f.input :marketing_email_opt_in %>
        <%= f.input :marketing_post_opt_in %>
        <%= f.input :marketing_representative_opt_in %>
      </div>
      <div class='form-actions button-container'>
        <%= button_tag(type: 'submit', class: 'btn btn-primary') do %>
          <%= t('layouts.application.enrole') %><i class='fi-arrow-right'></i>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

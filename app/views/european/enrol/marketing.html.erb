<section id="login__area" class="login__area">
  <div class="container marketing_opt_in">
    <div class="login__wrap">
      <div class="login__content">
        <h2><%= t('.title_html') %></h2>

        <div class="login__part">
          <p><%= t('.description_html') %></p>
          <%= simple_form_for(@user, url: users_locale_enrol_index_path, html: { class: 'form' }) do |f| %>
            <%= render 'tmp_storage_fields', f: f %>
            <p><%= t('.marketing_overall_opt_in_description_html') %></p>

            <%= f.input :marketing_overall_opt_in, label: t('.marketing_overall_opt_in_html') %>
            <p class='small'><%= t('.marketing_overall_opt_in_note_html') %></p>
            <p><%= t('.marketing_overall_description_html') %></p>
            <%= f.input :marketing_email_opt_in, label: t('.marketing_email_opt_in_label_html') %>
            <%= f.input :marketing_post_opt_in, label: t('.marketing_post_opt_in_label_html') %>
            <%= f.input :marketing_representative_opt_in, label: t('.marketing_representative_opt_in_label_html') %>

            <div class="submit d-flex justify-content-end">
              <%= button_tag(type: 'submit', class: 'login') do %>
                <%= t('layouts.application.enrol') %>
                <%= image_tag("right_angle_purple.svg") %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>

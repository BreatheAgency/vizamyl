<section id="login__area" class="login__area">
  <div class="container enrolment">
    <div class="login__wrap">
      <div class="login__content">
        <h2><%= t('.title_html') %></h2>
        <p><%= t('.description_one_html') %></p>

        <div class="login__part">
          <%= simple_form_for(@user, url: users_locale_enrol_path, html: { method: :put, class: 'form' }) do |f| %>
            <%= render 'tmp_storage_fields', f: f %>
            <%= f.input :terms_and_conditions_opt_in, required: true, label: t('.terms_accept_html') %>

            <% if (I18n.locale == :de || I18n.locale == :'de-at') %>
              <br>
              <%= t('.description_two_html') %>
              <div class='form-inputs'>
                <%= f.input :cookies_opt_in, required: true, label: t('.cookies_accept_html') %>
              </div>
            <% end %>

            <div class="submit d-flex justify-content-end">
              <%= button_tag(type: 'submit', class: 'login btn btn-primary') do %>
                <%= t('course.actions.next') %>
                <!-- <%= image_tag("right_angle_purple.svg") %> -->
                <span class="arrow-circle"><i class="fa fa-arrow-right-long arrow right"></i></span>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>

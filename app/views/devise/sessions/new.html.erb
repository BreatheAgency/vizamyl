<section id="login__area" class="login__area">
  <div class="container">
    <div class="login__wrap">
      <div class="login__content">
        <h2><%= t('.login') %></h2>

        <div class="login__part">
          <div class="welcome__content">
            <p>
              <%= simple_format t('.intro') %>
            </p>
          </div>
          <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name), html: { role: 'form' }) do |f| %>
            <%= f.error_notification %>
            <%= f.input :email, required: true, autofocus: true %>
            <%= f.input :password, required: true %>

            <div class="remember__forget">
              <div class="remember">
                <%= f.input :remember_me, as: :boolean, input_html: { checked: true } %>
              </div>
              <div class="forget">
                <a href="#" style="color: #000;">Forgot your password?</a>
              </div>
            </div>

            <div class="submit d-flex justify-content-end">
              <%= button_tag(type: 'submit', class: 'login') do %>
                <%= t('.login') %>
                <%= image_tag("right_angle_purple.svg") %>
              <% end %>
            </div>
          <% end %>
          </form>
          <script>
           $("#fake_check").change(function() {
             if(this.checked) {
               $("#user_remember_me").prop( "checked", true );
             } else {
               $("#user_remember_me").prop( "checked", false );
             }
           });
          </script>
        </div>
      </div>
    </div>
  </div>
</section>

<%= bootstrap_devise_error_messages! %>
<div class="devise row">
  <div class="small-6 medium-6 large-6 columns with-content with-minimum">
  </div>
  <div class="small-6 medium-6 large-6 columns with-content with-minimum">
    <h1 class="vh"><%= t('.sign_in') %></h1>
    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { role: 'form' }) do |f| %>
      <fieldset>
        <legend class="vh"><%= t('.sign_in') %></legend>
          <div class="form-group">
            <%= f.label :email %>
            <%= f.email_field :email, autofocus: true, class: 'form-control', value: 'en-user@example.com' %>
          </div>
          <div class="form-group">
            <%= f.label :password %>
            <%= f.password_field :password, autocomplete: 'off', class: 'form-control', value: 'password' %>
          </div>
          <span class="help-block"><%= link_to t('.forgot_your_password'), new_user_password_path %></span>
          <div class="checkbox">
            <label>
              <%= f.check_box :remember_me, checked: true %>
              <%= f.label :remember_me %>
          </div>
          <div class="button-container">
            <%= button_tag(type: 'submit', class: "btn btn-primary") do %>
              <%= t('.sign_in') %><i class="fi-arrow-right"></i>
            <% end %>
          </div>
      </fieldset>
    <% end %>
  </div>
</div>

<div class='locale-select'>
  <div class="row" style="margin:0 0 0 0;">
    <div class='large-3 left'>
      <hr>
      <%= render partial: 'errors/locale_block', locals: {locales: I18n.available_locales[1...6]} %>
    </div>
    <div class="large-9 left">
      <hr>
      <%= render partial: 'errors/locale_block', locals: {locales: I18n.available_locales.drop(6)} %>
      <%= link_to(ch_path, class: "locale") do %>
        <p class="country">Switzerland</p>
      <% end %>
      <hr>
      <a href="http://www.vizamyl.co.kr/" target="_blank" class="locale">
        <p class="country">South Korea</p>
      </a>
      <hr>
    </div>
  </div>
  <div class="row" style="margin:4em 0 0 0;">
    <div class='large-3 left'>
      <hr>
      <a href="/en" class="locale">
        <p class="country">International English</p>
      </a>
      <hr>
    </div>
    <div class='large-9 left'>
      <hr>
      <a href="/en" class="locale">
        <p class="language">GE Healthcare Representatives Use Only.</p>
      </a>
      <hr>
    </div>
  </div>
</div>

<div class='locale-select'>
  <div class='large-3 left'>
    <hr>
    <%= render partial: 'errors/locale_block', locals: {locales: I18n.available_locales[0...5]} %>
  </div>
  <div class="large-9 left">
    <hr>
    <%= render partial: 'errors/locale_block', locals: {locales: I18n.available_locales.drop(5)} %>
    <a href="http://readvizamyl.jp/" target="_blank" class="locale">
      <p class="country">Japan</p>
    </a>
    <hr>
    <a href="https://hls2.gehealthcare.com/content/unfiltered/LIFE-VIZAMYL-NONSCORM/" target="_blank" class="locale">
      <p class="country">United States</p>
    </a>
    <hr>
  </div>
  <div class="row">
    <div class='large-3 left' style="margin-top:4em;">
      <hr>
      <a href="/en" class="locale">
        <p class="country">International English</p>
      </a>
      <hr>
    </div>
    <div class='large-9 left' style="margin-top:4em;">
      <hr>
      <a href="/en" class="locale">
        <p class="language">GE representatives use only</p>
      </a>
      <hr>
    </div>
  </div>
</div>


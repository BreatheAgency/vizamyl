<ul class='locale-select'>
  <% I18n.available_locales.each do |locale| %>
    <li>
      <a href='<%= "/#{locale}" %>' class='<%= "#{locale}-button" %>'>
        <%= locale %>
      </a>
    </li>
  <% end %>
  <li>
    <a href="https://hls2.gehealthcare.com/content/unfiltered/LIFE-VIZAMYL-NONSCORM/" target="_blank" class='us-button'>US</a>
  </li>
  <li>
    <a href="http://readvizamyl.jp/" target="_blank" class='jp-button'>Japan</a>
  </li>
</ul>

<ul class='locale-label'>
  <li>
    <a href='/en' class='en-button'><p style='text-align:left'>Int English<br>GE representatives<br>use only</br></p></a>
  </li>
  <% I18n.available_locales.reject{|lang| lang == :en }.each do |locale| %>
    <li>
      <a href='<%= "/#{locale}" %>' class='<%= "#{locale}-button" %>'>
        <%= {
          'en-gb': 'United Kingdom',
          'pt': 'Portugal',
          'it': 'Italy',
          'fr': 'France',
          'es': 'Spain',
          'de': 'Germany',
          'de-at': 'Austria',
          'nl': 'Netherlands'
        }.fetch(locale, locale) %>
      </a>
      </a>
    </li>
  <% end %>
  <li>
    <a href="https://hls2.gehealthcare.com/content/unfiltered/LIFE-VIZAMYL-NONSCORM/" target="_blank" class='us-button' style='padding-left:20px;'>US</a>
  </li>
  <li>
    <a href="http://readvizamyl.jp/" target="_blank" class='jp-button' style='padding-left:10px;'>Japan</a>
  </li>
</ul>

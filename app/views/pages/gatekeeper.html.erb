<div class='row'>
  <div class='large-12 large-centered map'>
    <h1>VIZAMYL Flutemetamol F<sup>18</sup> Injection</h1>
    <h2>Electronic training programme</h2>
    <p><span class='blue'>This site is intended for medical professionals only</span><br> To proceed, please select which country you are from.</p>
    <ul class='locale-select'>
      <% I18n.available_locales.each do |locale| %>
        <li>
          <a href='<%= "/#{locale}" %>' class='<%= "#{locale}-button" %>'>
            <%= locale %>
          </a>
        </li>
      <% end %>
    </ul>
    <ul class='locale-label'>
      <% I18n.available_locales.each do |locale| %>
        <li>
          <a href='<%= "/#{locale}" %>' class='<%= "#{locale}-button" %>'>
            <%= t(".locale_titles.#{locale}_html") %>
          </a>
        </li>
      <% end %>
    </ul>
  </div>
</div>
